{{! Data: name?, otp, expiresIn }}

{{#if name}}
<p style="margin:0 0 16px;font-size:15px;color:#3f3f46;">Xin chào <strong>{{name}}</strong>,</p>
{{else}}
<p style="margin:0 0 16px;font-size:15px;color:#3f3f46;">Xin chào,</p>
{{/if}}

<h2 style="margin:0 0 12px;font-size:22px;font-weight:700;color:#18181b;line-height:1.3;">
  Đặt lại mật khẩu
</h2>

<p style="margin:0 0 20px;font-size:15px;color:#52525b;line-height:1.6;">
  Bạn đã yêu cầu đặt lại mật khẩu. Nhập mã OTP bên dưới để tiếp tục:
</p>

<table role="presentation" cellspacing="0" cellpadding="0" style="margin:0 0 24px;">
  <tr>
    <td style="background-color:#f4f4f5;border:2px dashed #d4d4d8;border-radius:8px;padding:16px 32px;text-align:center;">
      <span style="font-size:36px;font-weight:800;color:#18181b;letter-spacing:8px;font-family:'Courier New',Courier,monospace;">
        {{otp}}
      </span>
    </td>
  </tr>
</table>

<p style="margin:0 0 8px;font-size:13px;color:#a1a1aa;">
  ⏱ Mã này sẽ hết hạn sau <strong>{{expiresIn}}</strong>.
</p>
<p style="margin:0;font-size:13px;color:#ef4444;font-weight:500;">
  🔒 Không chia sẻ mã này với bất kỳ ai.
</p>
