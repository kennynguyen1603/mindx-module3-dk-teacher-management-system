{{! Reusable CTA button — props: url, text }}
<table role="presentation" cellspacing="0" cellpadding="0" style="margin:24px 0;">
  <tr>
    <td style="border-radius:6px;background-color:#18181b;">
      <a href="{{url}}"
         target="_blank"
         style="display:inline-block;padding:12px 24px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:6px;letter-spacing:0.1px;">
        {{text}}
      </a>
    </td>
  </tr>
</table>
