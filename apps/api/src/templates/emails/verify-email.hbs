{{! Data: name?, verifyUrl, expiresIn }}

{{#if name}}
<p style="margin:0 0 16px;font-size:15px;color:#3f3f46;">Xin chào <strong>{{name}}</strong>,</p>
{{else}}
<p style="margin:0 0 16px;font-size:15px;color:#3f3f46;">Xin chào,</p>
{{/if}}

<h2 style="margin:0 0 12px;font-size:22px;font-weight:700;color:#18181b;line-height:1.3;">
  Xác nhận địa chỉ email của bạn
</h2>

<p style="margin:0 0 8px;font-size:15px;color:#52525b;line-height:1.6;">
  Cảm ơn bạn đã đăng ký. Vui lòng click vào nút bên dưới để kích hoạt tài khoản.
</p>

{{> button url=verifyUrl text="Xác nhận email"}}

<p style="margin:0 0 8px;font-size:13px;color:#71717a;line-height:1.6;">
  Hoặc copy link này vào trình duyệt:
</p>
<p style="margin:0 0 20px;font-size:12px;color:#71717a;word-break:break-all;">
  {{verifyUrl}}
</p>

<p style="margin:0;font-size:13px;color:#a1a1aa;">
  ⏱ Link này sẽ hết hạn sau <strong>{{expiresIn}}</strong>.
</p>
